---
import { Image } from "astro:assets";
import computerImage from "../../assets/images/computer.png";

let skills = [
    {
        name: "HTML",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg",
    },
    {
        name: "CSS",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg",
    },
    {
        name: "JavaScript",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg",
    },
    {
        name: "PHP",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/php/php-original.svg",
    },
    {
        name: "MySQL",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original-wordmark.svg",
    },
    {
        name: "React",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original-wordmark.svg",
    },
    {
        name: "Next JS",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg",
    },
    {
        name: "Astro",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg",
    },
    {
        name: "Yii",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/yii/yii-original.svg",
    },
    {
        name: "Laravel",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/laravel/laravel-original.svg",
    },
    // {
    // 	name: "CSS",
    // 	logo: "",
    // },
];
---

<div class="hero min-h-screen">
    <div class="hero-content flex-col lg:flex-row-reverse">
        <img
            src={computerImage.src}
            alt="Computer on top of desk with plants around it"
            style={`width: clamp(100px, 400px, 75%);`}
        />
        <div>
            <h1 class="text-5xl font-bold">hi! i'm rene🍀</h1>
            <p class="py-6">
                I am a developer, based on the Philippines. I create things that
                live on the internet, whether that be websites, applications, or
                anything in between.
            </p>
            <button class="btn btn-primary">Get Started</button>
        </div>
    </div>
</div>

<div>
    {
        skills.map((skill) => (
            <div class="badge badge-lg">
                <img
                    class="hero--skills-logo"
                    src={skill.logo}
                    title={skill.name + " logo"}
                    loading="lazy"
                />
                <div class="hero--skills-name">{skill.name}</div>
            </div>
        ))
    }
</div>
